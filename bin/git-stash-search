#!/bin/sh
set -e

if [ -z "$1" ]; then
	echo "Usage: stash-search <pattern>"
	exit 1
fi

PATTERN=$1
STASHES=$(git stash list)

echo "$STASHES" | awk -F': ' '{print $1}' | while read -r stash; do
	if git stash show --name-only "$stash" | grep -q -- "$PATTERN"; then
		echo "  in $stash (files)"
		git stash show --name-only "$stash" | grep -- "$PATTERN" | sed 's/^/    - /'
	fi
done